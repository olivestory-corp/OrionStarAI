# Dependencies
node_modules
*/node_modules

# Build outputs (will be rebuilt in Docker)
client/build
server/dist

# Development files
.git
.gitignore
*.md
!README.md

# IDE
.idea
.vscode
.deepvcode

# Python
__pycache__
*.py
*.pyc

