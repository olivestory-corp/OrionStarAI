# Google Cloud 项目配置 (Vertex AI)
GOOGLE_CLOUD_PROJECT=您的项目ID
GOOGLE_CLOUD_LOCATION=us-central1

# Server Port
PORT=8081

# SSL Mode (set to 'true' to enable HTTPS/WSS)
USE_SSL=false

# OpenAI API Key
OPENAI_API_KEY=您的OpenAI-api-key

# Google Cloud 凭据文件（Vertex AI）
GOOGLE_APPLICATION_CREDENTIALS=您的谷歌云凭据json路径
