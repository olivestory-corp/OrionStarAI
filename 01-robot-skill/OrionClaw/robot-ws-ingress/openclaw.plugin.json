{
  "id": "robot-ws-ingress",
  "name": "Robot WS Ingress",
  "description": "Accepts robot WebSocket connections (LAN) and relays nav commands.",
  "version": "0.0.1",
  "configSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": { "type": "boolean", "default": true },
      "bind": { "type": "string", "default": "0.0.0.0" },
      "port": { "type": "integer", "minimum": 1, "maximum": 65535, "default": 18795 },
      "path": { "type": "string", "default": "/robot/ws" },
      "token": { "type": "string", "description": "Shared token required in the WS query (?token=...)." },
      "allowDeviceIds": { "type": "array", "items": { "type": "string" }, "default": [] },
      "gatewayPort": { "type": "integer", "default": 18789, "description": "Gateway WS port for cron.wake injection." },
      "gatewayToken": { "type": "string", "description": "Gateway auth token for cron.wake injection." }
    },
    "required": ["port", "path", "token"]
  },
  "uiHints": {
    "token": { "sensitive": true }
  }
}
